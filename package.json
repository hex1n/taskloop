{
  "name": "workloop",
  "version": "0.2.0",
  "description": "Work supervisor and portable loop kernel for coding agents",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "workloop": "bin/workloop.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node --test tests/authority-transaction.test.mjs tests/provider-installer.test.mjs tests/git-main-authority.test.mjs tests/git-task-receipts.test.mjs tests/git-linked-worktree-authority.test.mjs tests/git-partitioned-multitask-authority.test.mjs tests/git-exclusive-worktree-authority.test.mjs tests/filesystem-detached-authority.test.mjs tests/attachment-recovery-authority.test.mjs",
    "test:matrix": "node --test tests/authority-transaction.test.mjs tests/provider-installer.test.mjs tests/git-main-authority.test.mjs tests/git-linked-worktree-authority.test.mjs tests/git-partitioned-multitask-authority.test.mjs tests/git-exclusive-worktree-authority.test.mjs tests/filesystem-detached-authority.test.mjs tests/attachment-recovery-authority.test.mjs",
    "test:installer": "node --test tests/provider-installer.test.mjs",
    "install:user": "node install.mjs",
    "install:user:dry-run": "node install.mjs --dry-run"
  },
  "files": [
    "bin/",
    "lib/",
    "skills/",
    "install.mjs",
    "uninstall.mjs",
    "README.zh-CN.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hex1n/workloop.git"
  },
  "bugs": {
    "url": "https://github.com/hex1n/workloop/issues"
  },
  "homepage": "https://github.com/hex1n/workloop#readme"
}
